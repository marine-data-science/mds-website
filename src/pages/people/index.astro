---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageIntro from "@components/PageIntro.astro";
import Prose from "@components/Prose.astro";
import { bodyForIndex, getIndex, getPeopleCards, sectionIntro } from "@lib/content";

const index = await getIndex("people");
const people = await getPeopleCards();
const currentPeople = people.filter((person) => !person.alumni);
const intro = await sectionIntro("people");
const title = index.data.title;
const eyebrow = index.data.eyebrow ?? "People";
const body = bodyForIndex(index);
---

<BaseLayout title={title} description={intro}>
  <PageIntro eyebrow={eyebrow} title={title} intro={intro} />
  {body && (
    <section class="section overview-copy">
      <Prose markdown={body} />
    </section>
  )}
  <section class="section">
    <div class="people-list">
      {
        currentPeople.map((person) => (
          <article class="person-row">
            {person.image && (person.href ? <a class="person-image-link" href={person.href}><img class="person-avatar" src={person.image.src} alt={person.image.alt} loading="lazy" /></a> : <img class="person-avatar" src={person.image.src} alt={person.image.alt} loading="lazy" />)}
            <div>
              <h3>{person.href ? <a href={person.href}>{person.title}</a> : person.title}</h3>
              <p>{person.summary}</p>
              {person.href && <p class="micro-note"><a href={person.href}>More info</a></p>}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
