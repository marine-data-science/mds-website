---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageIntro from "@components/PageIntro.astro";
import { getThesisItems, groupThesisItems, sectionIntro } from "@lib/content";

const theses = getThesisItems();
const thesisGroups = groupThesisItems(theses);
---

<BaseLayout title="Theses" description={sectionIntro("theses")}>
  <PageIntro eyebrow="For students" title="Bachelor and Master Theses" intro={sectionIntro("theses")} />
  <section class="section">
    {
      thesisGroups.map((group) => (
        <section class="thesis-group">
          <div class="section-header compact">
            <h2>{group.status}</h2>
            <p>{group.items.length} {group.items.length === 1 ? "topic" : "topics"}</p>
          </div>
          <div class="thesis-list">
            {group.items.map((item) => (
              <article class="thesis-item">
                <span class="status">{item.status}</span>
                <h3>{item.href ? <a href={item.href}>{item.title}</a> : item.title}</h3>
                {item.description && <p>{item.description}</p>}
              </article>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
