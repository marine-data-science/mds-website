---
import BaseLayout from "@layouts/BaseLayout.astro";
import CardGrid from "@components/CardGrid.astro";
import {
  getIndex,
  getPeopleCards,
  getPreviewCard,
  getProjectCards,
  getResearchCards,
  getThesisItems,
} from "@lib/content";
import { withBasePath } from "@lib/site";

const home = getIndex("pages");
const researchCards = getResearchCards();
const projectCards = getProjectCards();
const people = getPeopleCards();
const theses = getThesisItems();
const preview = getPreviewCard();
const featuredResearch = researchCards.slice(0, 4);
const featuredProjects = projectCards.slice(0, 3);
const featuredPeople = people.slice(0, 4);
const featuredTheses = theses.filter((item) => item.status !== "Finished").slice(0, 4);
const researchHref = withBasePath("/research/");
const projectsHref = withBasePath("/projects/");
const peopleHref = withBasePath("/people/");
const thesesHref = withBasePath("/theses/");
---

<BaseLayout title="Marine Data Science" description={home.summary}>
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="accent-line" aria-hidden="true"></div>
        <p class="eyebrow">University of Rostock · Institute for Visual and Analytic Computing</p>
        <h1>Marine Data Science</h1>
        <p class="hero-copy">
          Research group working at the intersection of machine learning, marine data, sensor systems,
          probabilistic modeling, and visual computing.
        </p>
        <p class="hero-support">
          Member of the CORE Network. Students, researchers, institutions, and companies can find thesis topics,
          teaching, research expertise, and cooperation entry points here.
        </p>
        <div class="pill-row" aria-label="Entry points">
          <a class="pill" href={thesesHref}>Thesis topics</a>
          <a class="pill" href={researchHref}>Research topics</a>
          <a class="pill" href={projectsHref}>Cooperation</a>
        </div>
      </div>
      <aside class="preview-panel" aria-label="Selected research preview">
        {preview.image && <img src={preview.image.src} alt={preview.image.alt} />}
        <div>
          <p>{preview.meta ?? "Preview"}</p>
          <h2><a href={preview.href}>{preview.title}</a></h2>
        </div>
        <div class="network-mark" aria-hidden="true">
          <span class="network-dot"></span>
          <span class="network-dot"></span>
          <span class="network-dot"></span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2><a href={researchHref}>Research</a></h2>
      <p>Research topics across marine data, machine learning, sensor systems, uncertainty, and visual computing.</p>
    </div>
    <CardGrid cards={featuredResearch} />
    <p class="section-more"><a href={researchHref}>View all research</a></p>
  </section>

  <section class="section band">
    <div class="section-inner">
      <div class="section-header">
        <h2><a href={projectsHref}>Projects</a></h2>
        <p>Funded and applied projects connect research methods with logistics, industry, software interaction, teaching, and marine technology.</p>
      </div>
      <CardGrid cards={featuredProjects} variant="roomy" />
      <p class="section-more"><a href={projectsHref}>View all projects</a></p>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2><a href={peopleHref}>People</a></h2>
      <p>Researchers, coordinators, engineers, and students working across machine learning, marine data science, and visual computing.</p>
    </div>
    <div class="people-list">
      {
        featuredPeople.map((person) => (
          <article class="person-row">
            {person.image && (person.href ? <a class="person-image-link" href={person.href}><img class="person-avatar" src={person.image.src} alt={person.image.alt} loading="lazy" /></a> : <img class="person-avatar" src={person.image.src} alt={person.image.alt} loading="lazy" />)}
            <div>
              <h3>{person.href ? <a href={person.href}>{person.title}</a> : person.title}</h3>
              <p>{person.summary}</p>
              {person.href && <p class="micro-note"><a href={person.href}>More info</a></p>}
            </div>
          </article>
        ))
      }
    </div>
    <p class="section-more"><a href={peopleHref}>View all people</a></p>
  </section>

  <section class="theses-feature">
    <div class="theses-panel">
      <div>
        <p class="eyebrow">For students</p>
        <h2><a href={thesesHref}>Bachelor and Master Theses</a></h2>
        <p class="hero-support">
          We are always looking for motivated students. Open topics are listed, and students can also propose topics in the group's research areas.
        </p>
      </div>
      <div class="thesis-list">
        {
          featuredTheses.map((item) => (
            <article class="thesis-item">
              <span class="status">{item.status}</span>
              <h3>{item.href ? <a href={item.href}>{item.title}</a> : item.title}</h3>
              {item.description && <p>{item.description}</p>}
            </article>
          ))
        }
      </div>
      <p class="section-more theses-more"><a href={thesesHref}>View all thesis topics</a></p>
    </div>
  </section>
</BaseLayout>
