---
import { absoluteSiteUrl, withBasePath } from "@lib/site";
import "@styles/global.css";

type NavItem = {
  href: string;
  label: string;
};

const {
  title = "Marine Data Science",
  description = "Marine Data Science research group at the University of Rostock.",
} = Astro.props;

const nav: NavItem[] = [
  { href: withBasePath("/research/"), label: "Research" },
  { href: withBasePath("/projects/"), label: "Projects" },
  { href: withBasePath("/people/"), label: "People" },
  { href: withBasePath("/theses/"), label: "Theses" },
  { href: withBasePath("/teaching/"), label: "Teaching" },
  { href: withBasePath("/publications/"), label: "Publications" },
];

const logo = withBasePath("/brand/Logo_MDS_1-3-Final_color.svg");
const favicon = withBasePath("/brand/favicon.svg");
const faviconPng = withBasePath("/brand/favicon-32x32.png");
const appleTouchIcon = withBasePath("/brand/apple-touch-icon.png");
const socialImage = absoluteSiteUrl("/brand/social-card.png");
const homeHref = withBasePath("/");
const pageTitle = title === "Marine Data Science" ? title : `${title} · Marine Data Science`;
const canonicalUrl = absoluteSiteUrl(Astro.url.pathname);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Marine Data Science",
  url: absoluteSiteUrl("/"),
  logo: absoluteSiteUrl("/brand/Logo_MDS_1-3-Final_color.png"),
  parentOrganization: {
    "@type": "CollegeOrUniversity",
    name: "University of Rostock",
    url: "https://www.uni-rostock.de/",
  },
  address: {
    "@type": "PostalAddress",
    streetAddress: "Albert-Einstein-Str. 21",
    postalCode: "18059",
    addressLocality: "Rostock",
    addressCountry: "DE",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="alternate icon" href={faviconPng} type="image/png" sizes="33x33" />
    <link rel="apple-touch-icon" href={appleTouchIcon} sizes="180x180" />
    <meta name="theme-color" content="#00529F" />
    <meta property="og:site_name" content="Marine Data Science" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1060" />
    <meta property="og:image:height" content="490" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="top-rule" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href={homeHref} aria-label="Marine Data Science home">
        <img src={logo} alt="Marine Data Science logo" width="150" height="106" />
      </a>
      <nav class="desktop-nav" aria-label="Main navigation">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <details class="mobile-nav">
        <summary aria-label="Open navigation">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <nav aria-label="Mobile navigation">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </details>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src={logo} alt="" width="108" height="76" />
          <div>
            <h2>Marine Data Science</h2>
            <p>Research group at the University of Rostock<br />Institute for Visual and Analytic Computing</p>
          </div>
        </div>
        <div>
          <h3>Contact</h3>
          <p>Junior Professorship MDS<br />Albert-Einstein-Str. 21<br />18059 Rostock</p>
        </div>
        <div>
          <h3>Legal</h3>
          <p>
            <a href="https://www.uni-rostock.de/impressum/" target="_blank" rel="noopener noreferrer">Imprint</a><br />
            <a href="https://www.uni-rostock.de/datenschutz/" target="_blank" rel="noopener noreferrer">Privacy</a><br />
            <a href="https://www.uni-rostock.de/barrierefreiheit/" target="_blank" rel="noopener noreferrer">Accessibility</a>
          </p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© Marine Data Science · University of Rostock</p>
      </div>
    </footer>
  </body>
</html>
